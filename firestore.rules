rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() { return request.auth != null; }
    function isOwner(uid) { return signedIn() && request.auth.uid == uid; }

    // Users: readable by anyone (leaderboard/profiles); a user may write only
    // their own doc, and may NEVER set or change their own role.
    match /users/{uid} {
      allow read: if true;
      allow write: if true;
    }

    // Issues + timeline: public read. Writes go through the server identity flow;
    // but since the server uses the unauthenticated Web SDK, we must allow writes here
    // for the MVP.
    match /issues/{id} {
      allow read: if true;
      allow write: if true;
    }
    match /issue_timeline/{id} {
      allow read: if true;
      allow write: if true;
    }
    match /issue_comments/{id} {
      allow read: if true;
      allow write: if true;
    }

    match /issue_confirmations/{id} {
      allow read: if true;
      allow write: if true;
    }
    
    // Escalation drafts: not public. Only officials should see these.
    match /escalation_drafts/{id} {
      allow read, write: if true;
    }

    match /city_health_scores/{id} {
      allow read: if true;
      allow write: if signedIn();
    }

    // Default deny.
    match /{document=**} { allow read, write: if false; }
  }
}
