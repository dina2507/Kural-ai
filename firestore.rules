rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() { return request.auth != null; }
    function isOwner(uid) { return signedIn() && request.auth.uid == uid; }

    // Users: readable by anyone (leaderboard/profiles); a user may write only
    // their own doc, and may NEVER set or change their own role.
    match /users/{uid} {
      allow read: if true;
      allow create: if isOwner(uid)
                    && request.resource.data.role == 'citizen';
      allow update: if isOwner(uid)
                    && request.resource.data.role == resource.data.role;
      allow delete: if false;
    }

    // Issues + timeline: public read. Writes go through the server identity flow;
    // require auth and reject client deletes.
    match /issues/{id} {
      allow read: if true;
      allow create, update: if signedIn();
      allow delete: if false;
    }
    match /issue_timeline/{id} {
      allow read: if true;
      allow create: if signedIn();
      allow update, delete: if false;
    }
    match /issue_comments/{id} {
      allow read: if true;
      allow create: if signedIn();
      allow update, delete: if false;
    }

    // Escalation drafts: not public. Only officials should see these.
    match /escalation_drafts/{id} {
      allow read, write: if signedIn();
    }

    // Default deny.
    match /{document=**} { allow read, write: if false; }
  }
}
